# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=screener_backtest_db
EQUITY_OHLC_DB=equity_ohlc

# ── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-strong-secret-key

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# ── CSV Data Paths ────────────────────────────────────────────────────────
INDEX_CSV_DIR=/path/to/index/csv/dir
SCREENER_CSV_DIR=/path/to/screener/csv/dir
